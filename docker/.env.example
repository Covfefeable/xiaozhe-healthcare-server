COMPOSE_PROJECT_NAME=xiaozhe-medical

DB_USERNAME=postgres
DB_PASSWORD=xiaozhe123456
DB_DATABASE=xiaozhe_medical
DB_PORT=5432

# Postgres Performance Tuning
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_EFFECTIVE_CACHE_SIZE=4096MB
POSTGRES_STATEMENT_TIMEOUT=0
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=0

# Shared Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Aliyun OSS
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=xiaozhe-medical
ALIYUN_OSS_REGION=cn-hangzhou
ALIYUN_OSS_SIGNED_URL_EXPIRES=900
OSS_UPLOAD_MAX_SIZE_MB=20
OSS_OBJECT_PREFIX=dev

# Container runtime addresses used by docker-compose.yml:
# DATABASE_URL=postgresql+psycopg://${DB_USERNAME}:${DB_PASSWORD}@postgres:5432/${DB_DATABASE}
# REDIS_URL=redis://redis:6379/0
#
# Local debug addresses used when running services outside Docker against docker-compose.dev.yml:
# DATABASE_URL=postgresql+psycopg://${DB_USERNAME}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_DATABASE}
# REDIS_URL=redis://localhost:6379/0

# API Ports
MINIAPP_API_PORT=5001
ADMIN_API_PORT=5002
ADMIN_WEB_PORT=3000

# Optional service-to-service URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:5002/api

# Same database, separated migration lines and table naming conventions
MINIAPP_ALEMBIC_VERSION_TABLE=miniapp_alembic_version
MINIAPP_DB_TABLE_PREFIX=miniapp_
ADMIN_ALEMBIC_VERSION_TABLE=admin_alembic_version
ADMIN_DB_TABLE_PREFIX=admin_
ADMIN_ALLOW_REGISTER=false
ADMIN_JWT_SECRET_KEY=replace-admin-jwt-secret
ADMIN_JWT_ACCESS_TOKEN_EXPIRES=7200
ADMIN_CORS_ORIGINS=http://localhost:3000

# Gunicorn Configuration
SERVER_WORKER_AMOUNT=1
SERVER_WORKER_CLASS=gevent
SERVER_WORKER_CONNECTIONS=10
GUNICORN_TIMEOUT=360
